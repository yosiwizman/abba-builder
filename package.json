{
  "name": "abba",
  "productName": "Abba",
  "version": "0.19.0-beta.1",
  "description": "Free, local, open-source AI app builder",
  "main": ".vite/build/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/dyad-sh/dyad.git"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "node -e \"const fs=require('fs');['out','scaffold/node_modules'].forEach(p=>{try{fs.rmSync(p,{recursive:true,force:true})}catch{}})\"",
    "start": "electron-forge start",
    "dev:engine": "DYAD_ENGINE_URL=http://localhost:8080/v1 npm start",
    "staging:engine": "DYAD_ENGINE_URL=https://staging---dyad-llm-engine-kq7pivehnq-uc.a.run.app/v1 npm start",
    "staging:gateway": "DYAD_GATEWAY_URL=https://staging---litellm-gcp-cloud-run-kq7pivehnq-uc.a.run.app/v1 npm start",
    "package": "npm run clean && electron-forge package",
    "make": "npm run clean && electron-forge make",
    "publish": "npm run clean && electron-forge publish",
    "verify-release": "node scripts/verify-release-assets.js",
    "ts": "npm run ts:main && npm run ts:workers",
    "ts:main": "npx tsc -p tsconfig.app.json --noEmit",
    "ts:workers": "npx tsc -p workers/tsc/tsconfig.json --noEmit",
    "lint": "npx oxlint --fix",
    "lint:fix": "npx oxlint --fix --fix-suggestions --fix-dangerously",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "prettier:check": "npx prettier --check .",
    "prettier": "npx prettier --write .",
    "presubmit": "npm run prettier:check && npm run lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:visual": "node scripts/run-visual-tests.js",
    "test:visual:baseline": "node scripts/capture-baselines.js",
    "test:visual:compare": "node scripts/compare-versions.js",
    "extract-codebase": "ts-node scripts/extract-codebase.ts",
    "prepare": "husky install",
    "pre:e2e": "cross-env E2E_TEST_BUILD=true npm run package",
    "e2e": "playwright test",
    "e2e:shard": "playwright test --shard",
    "build": "tsc --noEmit --skipLibCheck && electron-forge make",
    "build:win": "electron-forge make --platform win32",
    "build:mac": "electron-forge make --platform darwin",
    "build:linux": "electron-forge make --platform linux",
    "fix:types": "tsc --noEmit --skipLibCheck",
    "clean:full": "rimraf dist out node_modules package-lock.json .vite && npm install",
    "test:integration": "npx tsx test-integration.ts",
    "dev:ui": "vite --config vite.ui.config.ts --port 5174 --strictPort",
    "test:ui:snap": "playwright test -c playwright.ui.config.ts",
    "install:browsers": "playwright install chromium",
    "test:ui:electron": "playwright test -c playwright.electron.config.ts",
    "metrics:summary": "npx tsx scripts/metrics-summary.ts",
    "diagnostics:claude": "npx tsx scripts/claude-diagnostics.ts",
    "smoke:integration": "npx tsx scripts/smoke-integration.ts",
    "metrics:analysis": "npx tsx scripts/metrics-analysis.ts",
    "preflight": "powershell -ExecutionPolicy Bypass -File scripts/preflight.ps1",
    "metrics:watch": "powershell -ExecutionPolicy Bypass -File scripts/metrics-watch.ps1",
    "perf:watch": "powershell -ExecutionPolicy Bypass -File scripts/perf-watch.ps1",
    "health:watch": "powershell -ExecutionPolicy Bypass -File scripts/health-watch.ps1",
    "logs:watch": "powershell -ExecutionPolicy Bypass -File scripts/logs-watch.ps1",
    "monitor:ui": "powershell -ExecutionPolicy Bypass -File scripts/monitor-ui.ps1",
    "monitor:ui:launch": "powershell -ExecutionPolicy Bypass -File scripts/monitor-ui.ps1 -LaunchApp"
  },
  "keywords": [],
  "author": {
    "name": "Will Chen",
    "email": "willchen90@gmail.com"
  },
  "license": "MIT",
