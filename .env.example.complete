# Abba AI Builder Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# AI SERVICE PROVIDERS
# ============================================

# Anthropic Claude API
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# OpenAI API
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-YOUR_KEY_HERE

# Google AI (Gemini)
# Get your key from: https://makersuite.google.com/app/apikey
GOOGLE_AI_API_KEY=YOUR_KEY_HERE

# OpenRouter (Optional - for additional models)
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE

# ============================================
# DATABASE CONFIGURATION
# ============================================

# Local SQLite Database (default)
DATABASE_URL=./data/abba.db

# Neon Database (Optional - for cloud database)
# Get credentials from: https://console.neon.tech/
NEON_API_KEY=YOUR_NEON_KEY_HERE
NEON_DATABASE_URL=postgresql://user:password@host/database

# Supabase (Optional - for backend services)
# Get from: https://app.supabase.com/
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_KEY=YOUR_SERVICE_KEY_HERE

# ============================================
# GITHUB INTEGRATION
# ============================================

# GitHub Personal Access Token
# Create at: https://github.com/settings/tokens
# Required scopes: repo, workflow, read:org
GITHUB_TOKEN=ghp_YOUR_TOKEN_HERE
GITHUB_USERNAME=your-username
GITHUB_EMAIL=your-email@example.com

# ============================================
# ANALYTICS & MONITORING
# ============================================

# PostHog Analytics (Optional)
# Get from: https://app.posthog.com/
POSTHOG_API_KEY=phc_YOUR_KEY_HERE
POSTHOG_HOST=https://app.posthog.com

# Sentry Error Tracking (Optional)
# Get from: https://sentry.io/
SENTRY_DSN=https://YOUR_DSN@sentry.io/PROJECT_ID

# ============================================
# APP CONFIGURATION
# ============================================

# Development Settings
NODE_ENV=development
DEBUG=false
LOG_LEVEL=info

# App Settings
APP_NAME=Abba
APP_VERSION=0.19.0-beta.1
APP_PORT=3000

# Electron Settings
ELECTRON_ENABLE_LOGGING=true
ELECTRON_ENABLE_STACK_DUMPING=true
ELECTRON_IS_DEV=true

# ============================================
# FEATURE FLAGS
# ============================================

# Enable/Disable Features
ENABLE_AUTO_UPDATE=true
ENABLE_TELEMETRY=false
ENABLE_EXPERIMENTAL_FEATURES=false
ENABLE_PYTHON_VALIDATION=false
ENABLE_VISUAL_TESTING=true

# ============================================
# API ENDPOINTS (Optional Custom Endpoints)
# ============================================

# Custom LLM Engine
DYAD_ENGINE_URL=http://localhost:8080/v1
DYAD_GATEWAY_URL=http://localhost:8081/v1

# Custom API Endpoints
CUSTOM_API_ENDPOINT=
CUSTOM_API_KEY=

# ============================================
# SECURITY
# ============================================

# Encryption Keys (Generate using: openssl rand -hex 32)
ENCRYPTION_KEY=
JWT_SECRET=

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# ============================================
# DEVELOPMENT TOOLS
# ============================================

# Playwright Testing
PLAYWRIGHT_BROWSERS_PATH=0
PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=0

# Vite Configuration
VITE_PORT=5173
VITE_HOST=localhost

# ============================================
# PATHS
# ============================================

# Custom paths (optional)
CUSTOM_DATA_PATH=
CUSTOM_LOG_PATH=
CUSTOM_TEMP_PATH=

# ============================================
# NOTES
# ============================================
# 1. Never commit your actual .env file to version control
# 2. Keep your API keys secure and rotate them regularly
# 3. Use different keys for development and production
# 4. Some features require specific API keys to function
# 5. Check the documentation for minimum required variables
